# Comma-separated list is supported for deployed preview + production origins.
FRONTEND_URL=http://localhost:5173

# Used to build the Google callback URL when GOOGLE_REDIRECT_URI is not set.
BACKEND_PUBLIC_URL=http://localhost:8000

# Must match an authorized redirect URI in Google Cloud Console:
# http://localhost:8000/api/auth/google/callback for local development.
# https://your-backend.example.com/api/auth/google/callback for production.
GOOGLE_REDIRECT_URI=

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Generate a long random value and never commit the real value.
JWT_SECRET=replace-with-a-long-random-secret
